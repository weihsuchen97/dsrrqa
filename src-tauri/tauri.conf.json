{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DSRRQA",
  "identifier": "com.user.dsrrqa",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "DSRRQA",
        "width": 380,
        "height": 680,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": true,
        "minWidth": 300,
        "minHeight": 500,
        "skipTaskbar": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU1NTAwQTAzN0YyN0JFQUEKUldTcXZpZC9Bd3BRNVhnSTBCN1ovMzNBVDhBWTY4NHZ0ZXFkUGxsL0dVTHBybmwwRFlJL1l3ZGcK",
      "endpoints": [
        "https://github.com/weihsuchen97/dsrrqa/releases/latest/download/latest.json"
      ]
    }
  }
}
